{
  "name": "gulp-template",
  "description": "Modern Gulp template for fast frontend development",
  "version": "2.1.0",
  "type": "module",
  "main": "gulpfile.js",
  "author": "HolyMolly",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=development gulp dev",
    "build:dev": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=development gulp build:dev",
    "build:prod": "cross-env NODE_OPTIONS=--no-deprecation NODE_ENV=production gulp build:prod",
    "lint": "eslint . --fix && stylelint \"src/**/*.{css,scss}\" --fix",
    "format": "prettier --write .",
    "tailwind:setup": "node .template/setup/tailwind/setup.js",
    "clean": "node -e \"import('fs').then(f=>f.rmSync('dist',{recursive:true,force:true}))\"",
    "clean:cache": "node -e \"import('fs').then(f=>['node_modules/.cache','.eslintcache','.stylelintcache'].forEach(p=>f.rmSync(p,{recursive:true,force:true})))\"",
    "clean:all": "node -e \"import('fs').then(f=>['node_modules','dist'].forEach(p=>f.rmSync(p,{recursive:true,force:true})))\""
  },
  "browserslist": [
    ">= 1%",
    "last 2 versions",
    "not dead"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "autoprefixer": "^10.4.21",
    "browser-sync": "^2.27.11",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.2.0",
    "gulp": "^4.0.2",
    "gulp-cached": "^1.1.1",
    "gulp-csso": "^4.0.1",
    "gulp-dart-sass": "^1.1.0",
    "gulp-if": "^3.0.0",
    "gulp-newer": "^1.4.0",
    "gulp-notify": "^5.0.0",
    "gulp-nunjucks-render": "^2.2.3",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "gulp-prettier": "^6.0.0",
    "gulp-remember": "^1.0.1",
    "gulp-sass-glob-use-forward": "^0.1.3",
    "gulp-size": "^5.0.0",
    "gulp-svg-sprite": "^2.0.3",
    "gulp-terser": "^2.1.0",
    "gulp-webp": "^5.0.0",
    "html-minifier-terser": "^7.2.0",
    "node-notifier": "^10.0.1",
    "postcss": "^8.5.3",
    "postcss-sort-media-queries": "^6.1.0",
    "prettier": "^3.8.0",
    "sass": "^1.83.4",
    "sharp": "^0.33.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "svgo": "^4.0.1"
  }
}
